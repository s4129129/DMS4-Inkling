  "calendar": {
    "sideRail": {
      "defaultWidthPx": 270,
      "minWidthPx": 220,
      "maxWidthPx": 420,
      "paddingRem": 0.9,
      "gapRem": 0.82,
      "resizeHandlePx": 10
    },
    "mainPanel": {
      "paddingRem": 0.9,
      "gapRem": 0.72,
      "mobileMinHeightVar": "--adaptive-calendar-main-min-height-phone",
      "tabletMinHeightVar": "--adaptive-calendar-main-min-height-medium"
    },
    "miniCards": {
      "radiusPx": 8,
      "paddingRem": 0.7,
      "headingFontRem": 0.94,
      "bodyFontRem": 0.82
    }
  },
  "adaptability": {
    "laptop": {
      "dashboardLayout": "fixed resizable sidebar plus fluid content",
      "calendarLayout": "resizable side rail, handle, fluid calendar",
      "readingTabs": "single horizontal tab row"
    },
    "mobile": {
      "dashboardLayout": "single column with non-resizable sidebar",
      "calendarLayout": "panel picker with hidden resize handle",
      "readingTabs": "horizontal scroll with smaller tab labels"
    }
  }
}
